# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs used in coverage
coverage

# Coverage directory used by tools like istanbul
**/coverage/

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn
.yarn-integrity
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Database files
*.db
*.db-shm
*.db-wal

# Session files
session.db*

# Build outputs
dist/
dist-test/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# AI Editor configs (local-only)
.cursor/
.claude/

# OS
.DS_Store
Thumbs.db

# Test data
.test-data/

# Temporary files
tmp/
temp/

# Media downloads
media/

# Images (downloaded/generated)
*.png
*.svg
*.jpg

# Audit
audit/

# Environment (secrets — use .env.example as the template)
.env

# QR session data and viewers (generated at runtime, may contain secrets)
qr-data.txt
qr-*.html

# Test output captures (run artifacts, not source)
test-output.txt
test-results*.txt

# Local cleanup scripts (contain machine-specific profile/catalog names)
scripts/cleanup.ps1
scripts/cleanup.sh

# Documentation archives (local-only historical snapshots)
**/archive/
**/archives/
**/archived/
