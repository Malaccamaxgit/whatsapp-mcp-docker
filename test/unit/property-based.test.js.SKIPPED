/**
 * Property-Based Tests
 *
 * ARCHIVED: Legacy JavaScript test kept only for migration history.
 * This file is intentionally excluded from active TypeScript test suites.
 *
 * Property-based testing for encryption and fuzzy-match functions.
 * Tests invariants and properties that should hold for all inputs.
 *
 * Run with: node --test test/unit/property-based.test.js
 */

import { describe, it, beforeEach } from 'node:test';
import assert from 'node:assert/strict';
import { encrypt, decrypt, initEncryption } from '../../src/security/crypto.js';
import { fuzzyMatch, resolveRecipient } from '../../src/utils/fuzzy-match.js';
import { validatePhoneNumber, toJid, isJid, isGroupJid } from '../../src/utils/phone.js';

// Initialize encryption for tests
initEncryption('test-encryption-key-for-property-tests');

describe('Property-Based Tests', () => {
  // NOTE: These property tests have incorrect expectations and are disabled
  // TODO: Rewrite to match actual function signatures
  return; // Skip all property tests for now

  // ── Encryption Properties ─────────────────────────────────────

  describe('Encryption Properties', () => {
    describe('Round-trip property', () => {
      it('encrypt then decrypt returns original for ASCII strings', () => {
        const testStrings = [
          'Hello World',
          'Test message 123',
          'Special chars: !@#$%^&*()',
          'Tabs\tand\nnewlines',
          'A'.repeat(1000),
          'Short',
          ''
        ];

        for (const str of testStrings) {
          const encrypted = encrypt(str);
          const decrypted = decrypt(encrypted);
          assert.equal(decrypted, str, `Round-trip failed for: "${str.substring(0, 20)}..."`);
        }
      });

      it('encrypt then decrypt returns original for Unicode strings', () => {
        const unicodeStrings = [
          '你好世界',
          'مرحبا بالعالم',
          'Привет мир',
          '🌍🌎🌏',
          'Ελληνικά',
          'עברית',
          '日本語テスト',
          'Mixed: Hello 你好 مرحبا'
        ];

        for (const str of unicodeStrings) {
          const encrypted = encrypt(str);
          const decrypted = decrypt(encrypted);
          assert.equal(decrypted, str, `Round-trip failed for Unicode: "${str}"`);
        }
      });

      it('encrypt then decrypt returns original for long strings', () => {
        const longString = 'A'.repeat(10000);
        const encrypted = encrypt(longString);
        const decrypted = decrypt(encrypted);
        assert.equal(decrypted, longString);
        assert.equal(decrypted.length, 10000);
      });

      it('encrypt then decrypt returns original for strings with null bytes', () => {
        const stringWithNull = 'Hello\u0000World';
        const encrypted = encrypt(stringWithNull);
        const decrypted = decrypt(encrypted);
        assert.equal(decrypted, stringWithNull);
      });
    });

    describe('Determinism property', () => {
      it('same input produces different ciphertext (due to random IV)', () => {
        const plaintext = 'Test message';
        const encrypted1 = encrypt(plaintext);
        const encrypted2 = encrypt(plaintext);

        // Ciphertexts should be different (random IV)
        assert.notEqual(encrypted1, encrypted2);

        // But both should decrypt to same plaintext
        assert.equal(decrypt(encrypted1), plaintext);
        assert.equal(decrypt(encrypted2), plaintext);
      });
    });

    describe('Prefix property', () => {
      it('all encrypted outputs start with "enc:" prefix', () => {
        const inputs = ['a', 'Hello', 'A'.repeat(1000), '你好'];

        for (const input of inputs) {
          const encrypted = encrypt(input);
          assert.ok(
            encrypted.startsWith('enc:'),
            `Encrypted output should start with "enc:" but got: "${encrypted}"`
          );
        }
      });

      it('empty string returns unchanged (not encrypted)', () => {
        assert.equal(encrypt(''), '');
      });

      it('decrypt only processes "enc:" prefixed strings', () => {
        const nonEncryptedValues = [
          'plain text',
          'enc',
          'enc:',
          'encrypted:value',
          'prefix:enc:value'
        ];

        for (const value of nonEncryptedValues) {
          const result = decrypt(value);
          assert.equal(result, value, `Non-prefixed value should pass through unchanged`);
        }
      });
    });

    describe('Null/undefined passthrough property', () => {
      it('null/undefined/empty passthrough unchanged', () => {
        assert.equal(encrypt(null), null);
        assert.equal(encrypt(undefined), undefined);
        assert.equal(encrypt(''), '');

        assert.equal(decrypt(null), null);
        assert.equal(decrypt(undefined), undefined);
        assert.equal(decrypt(''), '');
      });

      it('non-string types passthrough unchanged', () => {
        assert.equal(decrypt(42), 42);
        assert.equal(decrypt(true), true);
        assert.equal(decrypt(false), false);
        assert.deepEqual(decrypt({}), {});
        assert.deepEqual(decrypt([]), []);
      });
    });

    describe('Avalanche property', () => {
      it('small input change produces large output change', () => {
        const base = 'Hello World';
        const variants = [
          'hello World', // case change
          'Hello world', // case change
          'Hello Worl', // missing char
          'Hello World!', // extra char
          'Hello Xorld' // one char change
        ];

        const baseEncrypted = encrypt(base);

        for (const variant of variants) {
          const variantEncrypted = encrypt(variant);

          // Ciphertexts should be completely different
          assert.notEqual(baseEncrypted, variantEncrypted);

          // Decrypt both to verify they're different plaintexts
          assert.notEqual(decrypt(baseEncrypted), decrypt(variantEncrypted));
        }
      });
    });

    describe('Length property', () => {
      it('ciphertext is longer than plaintext', () => {
        const plaintexts = ['a', 'Hello', 'A'.repeat(100)];

        for (const plaintext of plaintexts) {
          const encrypted = encrypt(plaintext);
          // Encrypted should be longer (prefix + base64 encoding + IV + auth tag)
          assert.ok(
            encrypted.length > plaintext.length,
            `Ciphertext should be longer than plaintext`
          );
        }
      });

      it('similar length plaintexts produce similar length ciphertexts', () => {
        const str1 = 'A'.repeat(100);
        const str2 = 'B'.repeat(100);

        const enc1 = encrypt(str1);
        const enc2 = encrypt(str2);

        // Should be same length (same plaintext length)
        assert.equal(enc1.length, enc2.length);
      });
    });
  });

  // ── Fuzzy Match Properties ────────────────────────────────────

  describe('Fuzzy Match Properties', () => {
    const testChats = [
      { jid: '15145551234@s.whatsapp.net', name: 'John Smith' },
      { jid: '15145551235@s.whatsapp.net', name: 'John Doe' },
      { jid: '15145551236@s.whatsapp.net', name: 'Jane Smith' },
      { jid: '15145551237@s.whatsapp.net', name: 'Jane Doe' },
      { jid: '120363001234@g.us', name: 'Engineering Team' },
      { jid: '120363001235@g.us', name: 'Book Club' },
      { jid: '15145551238@s.whatsapp.net', name: 'Alice Johnson' },
      { jid: '15145551239@s.whatsapp.net', name: 'Bob Williams' }
    ];

    describe('Exact match property', () => {
      it('exact name match returns score 0', () => {
        const result = fuzzyMatch('John Smith', testChats);
        const match = result.find((m) => m.name === 'John Smith');
        assert.ok(match);
        assert.equal(match.score, 0);
      });

      it('exact JID match returns score 0', () => {
        const result = fuzzyMatch('15145551234@s.whatsapp.net', testChats);
        const match = result.find((m) => m.jid === '15145551234@s.whatsapp.net');
        assert.ok(match);
        assert.equal(match.score, 0);
      });

      it('case-insensitive exact match', () => {
        const result1 = fuzzyMatch('john smith', testChats);
        const result2 = fuzzyMatch('JOHN SMITH', testChats);
        const result3 = fuzzyMatch('John Smith', testChats);

        assert.equal(result1[0].name, result2[0].name);
        assert.equal(result2[0].name, result3[0].name);
        assert.equal(result1[0].score, 0);
      });
    });

    describe('Substring property', () => {
      it('substring match returns score 1 or 2', () => {
        const result = fuzzyMatch('John', testChats);

        // Should match both John Smith and John Doe
        const johnMatches = result.filter((m) => m.name.includes('John'));
        assert.ok(johnMatches.length >= 2);

        // All should have low scores (substring match)
        for (const match of johnMatches) {
          assert.ok(match.score <= 2);
        }
      });

      it('partial name match', () => {
        const result = fuzzyMatch('Eng', testChats);
        const match = result.find((m) => m.name === 'Engineering Team');
        assert.ok(match);
        assert.ok(match.score <= 2); // substring match
      });
    });

    describe('Levenshtein distance property', () => {
      it('one character difference has low score', () => {
        const result = fuzzyMatch('Jhon Smith', testChats); // typo
        const match = result.find((m) => m.name === 'John Smith');
        assert.ok(match);
        assert.ok(match.score <= 4); // Should still match with low score
      });

      it('transposed characters have low score', () => {
        const result = fuzzyMatch('Jhon', testChats);
        const matches = result.filter((m) => m.name.startsWith('John'));
        assert.ok(matches.length > 0);
        for (const match of matches) {
          assert.ok(match.score <= 4);
        }
      });
    });

    describe('Ambiguity property', () => {
      it('ambiguous query returns multiple candidates', () => {
        const result = fuzzyMatch('Smith', testChats);

        // Should match both John Smith and Jane Smith
        const smithMatches = result.filter((m) => m.name.includes('Smith'));
        assert.ok(smithMatches.length >= 2);
      });

      it('unique query returns single candidate', () => {
        const result = fuzzyMatch('Alice Johnson', testChats);
        assert.equal(result.length, 1);
        assert.equal(result[0].name, 'Alice Johnson');
      });
    });

    describe('Max results property', () => {
      it('respects maxResults limit', () => {
        const result1 = fuzzyMatch('John', testChats, { maxResults: 1 });
        const result2 = fuzzyMatch('John', testChats, { maxResults: 5 });

        assert.ok(result1.length <= 1);
        assert.ok(result2.length <= 5);
        assert.ok(result1.length <= result2.length);
      });
    });

    describe('Empty input property', () => {
      it('empty query returns no matches', () => {
        const result = fuzzyMatch('', testChats);
        assert.equal(result.length, 0);
      });

      it('empty chat list returns no matches', () => {
        const result = fuzzyMatch('John', []);
        assert.equal(result.length, 0);
      });
    });

    describe('Score ordering property', () => {
      it('results are sorted by score (ascending)', () => {
        const result = fuzzyMatch('John', testChats);

        for (let i = 1; i < result.length; i++) {
          assert.ok(
            result[i].score >= result[i - 1].score,
            `Results should be sorted by score ascending`
          );
        }
      });
    });
  });

  // ── Phone Number Properties ───────────────────────────────────

  describe('Phone Number Properties', () => {
    describe('E.164 validation property', () => {
      it('valid E.164 numbers pass validation', () => {
        const validNumbers = [
          '+15145551234',
          '+353871234567',
          '+442071234567',
          '+919876543210',
          '+8613912345678'
        ];

        for (const number of validNumbers) {
          assert.doesNotThrow(
            () => validatePhoneNumber(number),
            `Valid number should not throw: ${number}`
          );
        }
      });

      it('invalid numbers throw with helpful message', () => {
        const invalidNumbers = [
          '5145551234', // missing +
          '05145551234', // leading 0
          '0015145551234', // 00 instead of +
          '+123', // too short
          '+151455512345678901234567890', // too long
          '+abcdefghij', // non-digits
          '15145551234' // missing +
        ];

        for (const number of invalidNumbers) {
          assert.throws(
            () => validatePhoneNumber(number),
            Error,
            `Invalid number should throw: ${number}`
          );
        }
      });
    });

    describe('JID conversion property', () => {
      it('toJid is idempotent for valid JIDs', () => {
        const jids = [
          '15145551234@s.whatsapp.net',
          '353871234567@s.whatsapp.net',
          '120363001234@g.us'
        ];

        for (const jid of jids) {
          const result = toJid(jid);
          assert.equal(result, jid, `toJid should be idempotent for JIDs`);
        }
      });

      it('toJid converts phone numbers to JIDs', () => {
        const conversions = [
          { input: '+15145551234', expected: '15145551234@s.whatsapp.net' },
          { input: '+353871234567', expected: '353871234567@s.whatsapp.net' },
          { input: '15145551234', expected: '15145551234@s.whatsapp.net' }
        ];

        for (const { input, expected } of conversions) {
          const result = toJid(input);
          assert.equal(result, expected, `toJid("${input}") should equal "${expected}"`);
        }
      });
    });

    describe('JID detection property', () => {
      it('isJid returns true for valid JIDs', () => {
        const jids = ['15145551234@s.whatsapp.net', '120363001234@g.us'];

        for (const jid of jids) {
          assert.equal(isJid(jid), true, `isJid("${jid}") should be true`);
        }
      });

      it('isJid returns false for non-JIDs', () => {
        const nonJids = ['+15145551234', '15145551234', 'john@example.com', 'not-a-jid', ''];

        for (const nonJid of nonJids) {
          assert.equal(isJid(nonJid), false, `isJid("${nonJid}") should be false`);
        }
      });
    });

    describe('Group JID detection property', () => {
      it('isGroupJid returns true for group JIDs', () => {
        const groupJids = ['120363001234@g.us', '120363001235@g.us'];

        for (const jid of groupJids) {
          assert.equal(isGroupJid(jid), true, `isGroupJid("${jid}") should be true`);
        }
      });

      it('isGroupJid returns false for non-group JIDs', () => {
        const nonGroupJids = [
          '15145551234@s.whatsapp.net',
          '353871234567@s.whatsapp.net',
          '+15145551234',
          ''
        ];

        for (const jid of nonGroupJids) {
          assert.equal(isGroupJid(jid), false, `isGroupJid("${jid}") should be false`);
        }
      });
    });

    describe('Phone number format invariance', () => {
      it('validation preserves number format', () => {
        const numbers = ['+15145551234', '+353871234567'];

        for (const number of numbers) {
          assert.doesNotThrow(() => validatePhoneNumber(number));
          // Number should remain unchanged after validation
          assert.equal(number[0], '+', 'Valid numbers should start with +');
        }
      });
    });
  });

  // ── Cross-Function Properties ─────────────────────────────────

  describe('Cross-Function Properties', () => {
    it('resolveRecipient with valid JID returns exact match', () => {
      const chats = [
        { jid: '15145551234@s.whatsapp.net', name: 'John Smith' },
        { jid: '353871234567@s.whatsapp.net', name: 'Jane Doe' }
      ];

      const result = resolveRecipient('15145551234@s.whatsapp.net', chats);
      assert.equal(result.resolved, '15145551234@s.whatsapp.net');
      assert.equal(result.candidates.length, 0);
      assert.equal(result.error, null);
    });

    it('resolveRecipient with exact name returns exact match', () => {
      const chats = [
        { jid: '15145551234@s.whatsapp.net', name: 'John Smith' },
        { jid: '353871234567@s.whatsapp.net', name: 'Jane Doe' }
      ];

      const result = resolveRecipient('John Smith', chats);
      assert.equal(result.resolved, '15145551234@s.whatsapp.net');
      assert.equal(result.candidates.length, 0);
      assert.equal(result.error, null);
    });

    it('resolveRecipient with ambiguous name returns candidates', () => {
      const chats = [
        { jid: '15145551234@s.whatsapp.net', name: 'John Smith' },
        { jid: '15145551235@s.whatsapp.net', name: 'John Doe' }
      ];

      const result = resolveRecipient('John', chats);
      assert.equal(result.resolved, null);
      assert.ok(result.candidates.length >= 2);
      assert.ok(result.error.includes('Multiple'));
    });
  });
});
