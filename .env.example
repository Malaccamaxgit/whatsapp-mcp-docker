# WhatsApp MCP Server — Environment Variables
# For docker-compose workflows only. When using Docker MCP Toolkit,
# prefer storing secrets via:
#
#   docker mcp secret set whatsapp-mcp-docker.data_encryption_key
#
# For docker-compose, copy this file to .env and change the values:
#
#   cp .env.example .env
#
# The .env file is excluded from git and Docker builds.

# =============================================================================
# ENCRYPTION & SECURITY
# =============================================================================

# AES-256-GCM encryption for message bodies, sender names,
# and media metadata at rest. Generate a strong passphrase:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY=change-me-to-a-strong-passphrase

# =============================================================================
# AUTHENTICATION SETTINGS
# =============================================================================

# authenticate tool defaults (docker-compose; Docker MCP Toolkit uses profile config auth_*)
# These control the default behavior of the authenticate tool:

# AUTH_WAIT_FOR_LINK=true
#   If true, authenticate tool polls until device links or timeout
#   Set to false to return immediately after showing pairing code/QR
#   Default: true

# AUTH_LINK_TIMEOUT_SEC=120
#   Maximum seconds to wait for device link when waitForLink is true
#   Range: 15-600 seconds
#   Default: 120

# AUTH_POLL_INTERVAL_SEC=5
#   Interval between connection checks when waiting for link
#   Range: 2-60 seconds
#   Default: 5

# =============================================================================
# DATA RETENTION
# =============================================================================

# MESSAGE_RETENTION_DAYS=90
#   Auto-delete messages, media, and approvals older than this many days
#   Set to 0 to disable auto-purge (not recommended for compliance)
#   Default: 90

# =============================================================================
# ACCESS CONTROL
# =============================================================================

# ALLOWED_CONTACTS=+1234567890,+0987654321
#   Comma-separated list of WhatsApp JIDs or phone numbers allowed for outbound messages
#   If not set, all contacts are allowed (use with caution)
#   Example: ALLOWED_CONTACTS="+15145551234,+353871234567"

# =============================================================================
# STORAGE PATHS
# =============================================================================

# STORE_PATH=/data/store
#   Directory for message store database and media files
#   Default: /data/store

# AUDIT_DB_PATH=/data/audit/audit.db
#   Path to SQLite database for audit logs
#   Default: /data/audit/audit.db

# AUDIT_FALLBACK_PATH=/data/audit/audit-fallback.log
#   Path to fallback log file when database unavailable
#   Default: /data/audit/audit-fallback.log

# =============================================================================
# RATE LIMITING (Advanced)
# =============================================================================

# RATE_LIMIT_PER_MIN=60
#   Maximum outbound messages per minute.
#   60 = 1/sec sustained, comfortable for AI assistant conversations.
#   Default: 60

# DOWNLOAD_RATE_LIMIT_PER_MIN=30
#   Maximum media downloads per minute.
#   Default: 30

# AUTH_ATTEMPTS_PER_WINDOW and AUTH_WINDOW_MS are not env-configurable;
# they are fixed in code to protect against WhatsApp account bans.

# =============================================================================
# FILE UPLOAD SECURITY
# =============================================================================

# MAX_FILE_SIZE_MB=64
#   Maximum allowed file size for media uploads
#   Default: 64

# MEDIA_QUOTA_MB=512
#   Total media storage quota
#   Default: 512

# =============================================================================
# NOTES
# =============================================================================
# 
# Security Best Practices:
# 1. Always set DATA_ENCRYPTION_KEY in production
# 2. Use Docker MCP Toolkit secrets instead of .env files when possible
# 3. Enable host-level volume encryption for sensitive deployments
# 4. Set appropriate MESSAGE_RETENTION_DAYS for compliance
# 5. Restrict ALLOWED_CONTACTS in production environments
#
# For more information, see:
# - docs/README.md - Deployment guide
# - PRIVACY.md - Privacy and compliance documentation
# - docs/API.md - Complete API reference
